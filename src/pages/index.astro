---
---
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>AngelwebStudios | Portfolio</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .container {
      background: white;
      padding: 3rem;
      border-radius: 20px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      text-align: center;
      max-width: 500px;
    }
    h1 {
      color: #333;
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    p {
      color: #666;
      font-size: 1.2rem;
      margin-bottom: 2rem;
    }
    .btn {
      background: #ff6b6b;
      color: white;
      padding: 15px 30px;
      border: none;
      border-radius: 50px;
      font-size: 1.1em;
      cursor: pointer;
      transition: all 0.3s ease;
      margin: 10px;
    }
    .btn:hover {
      transform: scale(1.05);
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>✨ AngelwebStudios ✨</h1>
    <p>¡Tu portfolio está LIVE!</p>
    <button class="btn" onclick="alert('¡Hola desde AngelwebStudios!')">¡Funciona!</button>
    <br>
    <button class="btn" onclick="document.body.style.background='linear-gradient(135deg, #ff6b6b 0%, #feca57 100%)'">Cambiar Color</button>
  </div>
</body>
</html>
